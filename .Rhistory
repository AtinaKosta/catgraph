mca_var_contrib$mca_label)
if (!any(idx)) idx <- grepl(v, mca_var_contrib$mca_label, fixed = TRUE)
data.frame(
node = v,
mca_contrib_dim1_dim2 = sum(mca_var_contrib$contrib_dim1[idx], mca_var_contrib$contrib_dim2[idx], na.rm = TRUE),
stringsAsFactors = FALSE
)
}) |> bind_rows()
var_bridge <- var_bridge |>
left_join(nc_var, by = "node") |>
arrange(desc(strength))
