tea_with_demos <- cbind(tea_active, demos)
jb <- joint_balance(
data = tea_with_demos,
preferences = colnames(tea_active),
stratifiers = demo_cols,
B_omni = 500,
B_edge = 500,
alpha = 0.05
)
tea_with_demos <- cbind(tea_active, demos)
jb_list <- lapply(demo_cols, function(g) {
cat("\nRunning joint_balance for:", g, "\n")
joint_balance(
data        = tea_with_demos,
group       = g,
variables   = colnames(tea_active),
n_perm      = 500,
n_perm_edge = 500,
alpha       = 0.05,
seed        = 2026,
verbose     = FALSE
)
})
names(jb_list) <- demo_cols
cat("\n--- Joint balance test results ---\n")
for (g in names(jb_list)) {
cat("\n==============================\n")
cat("Grouping variable:", g, "\n")
cat("==============================\n")
print(jb_list[[g]])
print(summary(jb_list[[g]]))
}
plot(jb)
cat("\n--- Joint balance test results ---\n")
for (g in names(jb_list)) {
cat("\n==============================\n")
cat("Grouping variable:", g, "\n")
cat("==============================\n")
print(jb_list[[g]])
print(summary(jb_list[[g]]))
}
print(plot(jb_list[[g]]))
plot(jb_list)
# Sex-specific modality graphs
mg_m <- build_conditional_modality_graph(tea_with_demos, given = list(sex = "M"))
mg_f <- build_conditional_modality_graph(tea_with_demos, given = list(sex = "F"))
mg_m <- prune_modality_edges(mg_m, min_weight = 0.10, max_p = 0.05)
mg_f <- prune_modality_edges(mg_f, min_weight = 0.10, max_p = 0.05)
compare_modality_graphs(list(Men = mg_m, Women = mg_f),
restrict = "common", pruning = "none", signed = TRUE)
diffs_sex <- test_modality_edge_differences(mg_m, mg_f, n_perm = 500)
print(head(diffs_sex[order(diffs_sex$adj_p), ], 10))
gravity_cmp_sex <- compare_gravity(list(men = mg_m, women = mg_f), plot = FALSE)
print(head(gravity_cmp_sex[order(-abs(gravity_cmp_sex$delta_mgi_diff)), ], 10))
plot(gravity_cmp_sex, top_n = 10)
# Age comparison: first vs last age_Q level
age_levels <- levels(tea$age_Q)
youngest <- age_levels[1]
oldest <- age_levels[length(age_levels)]
mg_young <- build_conditional_modality_graph(tea_with_demos, given = list(age_Q = youngest))
mg_old <- build_conditional_modality_graph(tea_with_demos, given = list(age_Q = oldest))
mg_young <- prune_modality_edges(mg_young, min_weight = 0.10, max_p = 0.05)
mg_old <- prune_modality_edges(mg_old, min_weight = 0.10, max_p = 0.05)
compare_modality_graphs(list(Youngest = mg_young, Oldest = mg_old),
restrict = "common", pruning = "none", signed = TRUE)
age_cmp <- compare_gravity(list(young = mg_young, old = mg_old), plot = FALSE)
print(head(age_cmp[order(-abs(age_cmp$delta_mgi_diff)), ], 10))
plot(age_cmp, top_n = 10)
# ---- 8. Method comparison table ---------------------------------------------
comparison_table <- data.frame(
Property = c(
"Primary object",
"Visualisation of categories/modalities",
"Dimensionality assumption",
"Sparse representation",
"Variable-level structure",
"Modality-level structure",
"Association sign",
"Prevalence-aware ranking",
"Multiplicity control",
"Inference",
"Group comparison"
),
MCA_FactoMineR = c(
"Low-dimensional factor-space coordinates",
"Active category map; contribution and cos2 diagnostics",
"Projection onto latent axes; Dim 1-2 may explain limited inertia",
"No; all active categories remain in the map",
"Indirect via variable/category contributions",
"Coordinates of category points",
"Not encoded as attraction/repulsion edges",
"Mass exists, but no asymmetric pull metric",
"Not a native focus of descriptive MCA output",
"Mainly descriptive unless extended externally",
"Supplementary variables can be projected; formal network invariance not native"
),
catgraph = c(
"Pairwise association networks",
"Variable network and modality network",
"No forced two-dimensional projection for estimation",
"Yes; effect-size and p-value pruning",
"Explicit weighted graph with corrected Cramer's V",
"Explicit modality graph with phi edges",
"Signed residuals support attraction/repulsion interpretation",
"MGI, dMGI, and OS incorporate modality prevalence",
"BH or Holm pruning where implemented",
"Chi-square, bootstrap, permutation modules where implemented",
"joint_balance(), graph equality, edge-difference, gravity comparison"
),
stringsAsFactors = FALSE
)
print(knitr::kable(comparison_table, format = "pipe"))
# ---- 9. Save results ---------------------------------------------------------
results_for_paper <- list(
tea_dimensions = dim(tea),
active_variable_levels = sapply(tea_active, function(x) length(levels(x))),
mca_eigenvalues = mca_eig,
mca_top_dim1_contributions = top_dim1,
catgraph_variable_summary = list(
n_variables = igraph::vcount(cg_p$graph),
n_edges = igraph::ecount(cg_p$graph),
centrality = nc_var
),
catgraph_modality_summary = list(
n_modalities = igraph::vcount(mg_p$graph),
n_edges = igraph::ecount(mg_p$graph),
communities = comm_summary
),
gravity = grav,
node_centrality_modality = nc_mod,
rho_eigenvector_vs_dMGI = rho_eig_dMGI,
satellite_paradox_cases = satellites_high_eig,
mca_catgraph_modality_bridge = mca_catgraph_mod,
joint_balance = jb,
edge_differences_by_sex = diffs_sex,
gravity_comparison_by_sex = gravity_cmp_sex,
gravity_comparison_by_age = age_cmp,
comparison_table = comparison_table,
session_info = sessionInfo()
)
