title = "Preference network (BH p<0.05, V>=0.10)")
# Plot 2: Heatmap with effect sizes
plot_heatmap(cg, title = "Preference associations (Cramer's V)")
mg <- build_modality_graph(dat_pref)
mg_pruned <- prune_modality_edges(mg, min_weight = 0.10, max_p = 0.05)
cat("\n=== Modality-level preference network ===\n")
cat("Modalities:", igraph::vcount(mg_pruned$graph), "\n")
cat("Edges (after pruning):", igraph::ecount(mg_pruned$graph), "\n\n")
# Detect communities
set.seed(1)
mg_clust <- cluster_modalities(mg_pruned, method = "louvain", signed = FALSE)
comm <- igraph::V(mg_clust$graph)$cluster
# Filter to substantial communities only (>= 3 modalities)
comm_sizes <- table(comm)
big_comms  <- as.integer(names(comm_sizes[comm_sizes >= 3L]))
keep_nodes <- which(comm %in% big_comms)
mg_keep <- mg_clust
mg_keep$graph <- igraph::induced_subgraph(mg_clust$graph, vids = keep_nodes)
cat("Substantial communities (>=3 modalities):", length(big_comms), "\n")
cat("Modalities in substantial communities:",
igraph::vcount(mg_keep$graph), "\n\n")
# Compose interpretive labels for each community based on its content
# (this is editorial; you can rename based on what you see)
comm_labels_initial <- sapply(big_comms, function(cc) {
modalities <- igraph::V(mg_clust$graph)$name[comm == cc]
paste0("Community_", cc)
})
cat("Community membership:\n")
mod_df <- data.frame(
community = comm[keep_nodes],
variable  = sub("=.*", "", igraph::V(mg_keep$graph)$name),
modality  = igraph::V(mg_keep$graph)$name,
stringsAsFactors = FALSE
)
mod_df <- mod_df[order(mod_df$community, mod_df$variable), ]
print(mod_df, row.names = FALSE)
# Editorial labels (refine these based on what you see in your data)
comm_label_map <- list(
"1" = "Casual / cautious",
"3" = "Delivery-driven",
"4" = "Trust & reviews",
"5" = "Other / miscellaneous"
)
mod_df$label <- vapply(as.character(mod_df$community),
function(k) comm_label_map[[k]] %||% paste0("C", k),
character(1))
# --- Community palette and singleton reporting -----------------------------
n_big <- length(big_comms)
pal_comm <- grDevices::hcl.colors(n_big, palette = "Dark 3")
names(pal_comm) <- as.character(big_comms)
# Report the small / dropped communities so the reader knows they exist
small_comms <- as.integer(names(comm_sizes[comm_sizes < 3L]))
if (length(small_comms) > 0L) {
cat("\nSmall communities (<3 modalities, excluded from the plot):\n")
for (s in small_comms) {
members <- igraph::V(mg_clust$graph)$name[comm == s]
cat(sprintf("  Community %d (n=%d): %s\n",
s, length(members), paste(members, collapse = "; ")))
}
cat("\n")
}
v_comm <- as.character(comm[keep_nodes])
v_col  <- pal_comm[v_comm]
# --- Edge colours: green = attraction, red = repulsion ---------------------
sr <- igraph::E(mg_keep$graph)$std_resid
base_col <- ifelse(is.na(sr), "grey60",
ifelse(sr > 0, "#1D9E75", "#D85A30"))
e_alpha  <- pmax(pmin(abs(sr) / 10, 1), 0.20)
e_col    <- mapply(function(c, a) grDevices::adjustcolor(c, alpha.f = a),
base_col, e_alpha)
# --- Edge widths scaled to phi --------------------------------------------
phi <- igraph::E(mg_keep$graph)$weight
e_width <- pmax(phi, 0.05) * 8
# --- Layout (Fruchterman-Reingold, then rescale to a known box) ----------
set.seed(1)
lay <- igraph::layout_with_fr(mg_keep$graph)
lay[, 1L] <- scales::rescale(lay[, 1L], to = c(-1, 1))
lay[, 2L] <- scales::rescale(lay[, 2L], to = c(-1, 1))
# --- Compute label angle for each vertex pointing outward from the centre -
node_angle <- atan2(lay[, 2L], lay[, 1L])
# --- Plot device with extra right margin for legends ---------------------
op <- graphics::par(mar = c(1, 1, 3, 14), xpd = NA)
on.exit(graphics::par(op), add = TRUE)
plot(mg_keep$graph,
layout              = lay,
vertex.color        = v_col,
vertex.size         = 11,
vertex.frame.color  = "white",
vertex.label        = igraph::V(mg_keep$graph)$name,
vertex.label.cex    = 0.5,
vertex.label.dist   = 1.2,
vertex.label.degree = node_angle,
vertex.label.color  = "black",
vertex.label.family = "sans",
edge.width          = e_width,
edge.color          = e_col,
edge.curved         = 0,
main                = sprintf(
"Preference modality network: %d substantive community-orientations",
n_big),
rescale = FALSE, xlim = c(-1.05, 1.05), ylim = c(-1.05, 1.05))
# --- Legend 1: communities (top right) -----------------------------------
legend_labels <- vapply(as.character(big_comms), function(k) {
lab <- comm_label_map[[k]]
if (is.null(lab)) paste0("Community ", k) else lab
}, character(1))
graphics::legend(
x = 1.15, y = 0.8,
legend = legend_labels,
col    = pal_comm,
pch    = 19, pt.cex = 1.6,
bty    = "n", cex = 0.8,
title  = "Preference orientation",
title.adj = 0
)
# --- Legend 2: edge sign (middle right) ----------------------------------
graphics::legend(
x = 1.15, y = 0.1,
legend = c("attraction (+ residual)",
"repulsion (- residual)"),
col    = c("#1D9E75", "#D85A30"),
lwd    = 3, bty = "n", cex = 0.8,
title  = "Edge direction",
title.adj = 0
)
# --- Legend 3: edge width (bottom right) ---------------------------------
phi_breaks <- pretty(range(phi, na.rm = TRUE), n = 3)
phi_breaks <- phi_breaks[phi_breaks > 0]
if (length(phi_breaks) >= 2L) {
graphics::legend(
x = 1.15, y = -0.35,
legend = sprintf("phi = %.2f", phi_breaks),
col    = "grey40",
lwd    = pmax(phi_breaks, 0.05) * 8,
bty    = "n", cex = 0.8,
title  = "Edge weight",
title.adj = 0
)
}
cat("\n=== Modality centrality ===\n")
g_full <- mg_keep$graph
cent_df <- data.frame(
modality    = igraph::V(g_full)$name,
variable    = sub("=.*", "", igraph::V(g_full)$name),
community   = comm[keep_nodes],
community_label = vapply(as.character(comm[keep_nodes]), function(k) {
lab <- comm_label_map[[k]]
if (is.null(lab)) paste0("C", k) else lab
}, character(1)),
strength    = igraph::strength(g_full, weights = igraph::E(g_full)$weight),
betweenness = igraph::betweenness(g_full,
weights = 1 / igraph::E(g_full)$weight,
normalized = TRUE),
eigenvector = igraph::eigen_centrality(g_full,
weights = igraph::E(g_full)$weight)$vector,
stringsAsFactors = FALSE
)
cat("\nTop 10 modalities by STRENGTH (most-co-endorsed):\n")
print(head(cent_df[order(-cent_df$strength),
c("modality", "community_label", "strength")], 10),
row.names = FALSE, digits = 3)
cat("\nTop 10 modalities by BETWEENNESS (bridges between communities):\n")
print(head(cent_df[order(-cent_df$betweenness),
c("modality", "community_label", "betweenness")], 10),
row.names = FALSE, digits = 3)
cat("\nTop 10 modalities by EIGENVECTOR (core / prototypical):\n")
print(head(cent_df[order(-cent_df$eigenvector),
c("modality", "community_label", "eigenvector")], 10),
row.names = FALSE, digits = 3)
cent_plot <- function(values, title, lay_in, comm_in, pal_in) {
# Scale node sizes from 6 to 22 by value rank
if (max(values) > 0) {
sz <- 6 + (values - min(values)) / (max(values) - min(values)) * 16
} else {
sz <- rep(11, length(values))
}
v_col_local <- pal_in[as.character(comm_in)]
plot(g_full,
layout = lay_in,
vertex.color = v_col_local,
vertex.size  = sz,
vertex.frame.color = "white",
vertex.label = NA,
edge.width   = pmax(igraph::E(g_full)$weight, 0.05) * 5,
edge.color   = grDevices::adjustcolor("grey40", 0.4),
edge.curved  = 0,
main = title,
rescale = FALSE,
xlim = c(-1.05, 1.05), ylim = c(-1.05, 1.05))
}
op <- graphics::par(mfrow = c(2, 2),
mar = c(1, 1, 3, 1),
oma = c(0, 0, 0, 0))
on.exit(graphics::par(op), add = TRUE)
# Re-use the layout from section 4 so the four panels align spatially
# (lay was computed there)
cent_plot(cent_df$strength,
"Strength (sum of phi)",
lay, comm[keep_nodes], pal_comm)
cent_plot(cent_df$betweenness,
"Betweenness (bridge role)",
lay, comm[keep_nodes], pal_comm)
cent_plot(cent_df$eigenvector,
"Eigenvector (core position)",
lay, comm[keep_nodes], pal_comm)
# Fourth panel: a discrepancy plot — high betweenness, low eigenvector
# (modalities that bridge but aren't core to any community)
discrepancy <- rank(cent_df$betweenness) - rank(cent_df$eigenvector)
cent_plot(pmax(discrepancy, 0),
"Bridges (high betweenness, low eigenvector)",
lay, comm[keep_nodes], pal_comm)
graphics::par(op)
cat("\n(Centrality panel: same layout, node size encodes the measure)\n")
cat("\n=== Centrality bar charts ===\n")
# Helper for a single bar-chart panel
cent_bars <- function(df, measure_col, title, n_top = 12,
pal_comm_in = pal_comm,
label_map = comm_label_map) {
d <- df[order(-df[[measure_col]]), ]
d <- d[seq_len(min(n_top, nrow(d))), ]
# Reverse for horizontal-bar ordering (largest at top)
d <- d[rev(seq_len(nrow(d))), ]
bar_cols <- pal_comm_in[as.character(d$community)]
# Long modality names — abbreviate for axis but keep recognisable
abbreviate_modality <- function(x, max_len = 38) {
ifelse(nchar(x) > max_len,
paste0(substr(x, 1, max_len - 1), "\u2026"),
x)
}
display_names <- abbreviate_modality(d$modality)
vals <- d[[measure_col]]
bp <- graphics::barplot(
vals,
horiz     = TRUE,
names.arg = display_names,
las       = 1,
col       = bar_cols,
border    = NA,
cex.names = 0.6,
cex.axis  = 0.7,
main      = title,
cex.main  = 0.9,
xlab      = ""
)
# Add value labels at the end of each bar, positioned to avoid overflow
graphics::text(
x      = vals,
y      = bp,
labels = formatC(vals, format = "f", digits = 3),
pos    = 4,
cex    = 0.6,
col    = "grey30",
xpd    = NA
)
invisible(bp)
}
# Compute bridging score (rank difference between betweenness and eigenvector)
# and store as a column. Positive = bridges more than core; negative = core
# more than bridges; zero = balanced.
cent_df$bridge_score <- rank(cent_df$betweenness) - rank(cent_df$eigenvector)
# 2x2 layout. Generous left margin for modality names — they're long.
op_bars <- graphics::par(
mfrow = c(2, 2),
mar   = c(3, 16, 2.5, 6),    # bottom, left, top, right
oma   = c(2, 0, 2, 0),
xpd   = FALSE
)
on.exit(graphics::par(op_bars), add = TRUE)
cent_bars(cent_df, "strength",
"Strength (sum of phi over incident edges)")
cent_bars(cent_df, "betweenness",
"Betweenness (fraction of shortest paths)")
cent_bars(cent_df, "eigenvector",
"Eigenvector (core position)")
cent_bars(cent_df, "bridge_score",
"Bridge score (betweenness rank \u2212 eigenvector rank)")
# Outer title and shared community legend at the bottom
graphics::mtext("Modality centrality across measures (top 12 per panel)",
outer = TRUE, line = 0.5, cex = 1.05, font = 2)
# Reset for the legend below the panel grid
graphics::par(fig = c(0, 1, 0, 0.06), new = TRUE,
mar = c(0, 0, 0, 0), oma = c(0, 0, 0, 0))
graphics::plot.new()
legend_labels_bars <- vapply(as.character(big_comms), function(k) {
lab <- comm_label_map[[k]]
if (is.null(lab)) paste0("Community ", k) else lab
}, character(1))
graphics::legend("center",
legend = legend_labels_bars,
fill   = pal_comm,
border = NA, bty = "n",
horiz  = TRUE, cex = 0.85,
title  = NULL)
graphics::par(op_bars)
cat("Bar charts: top 12 modalities by each measure, coloured by community.\n")
cat("The bridge-score panel highlights modalities that act as cross-community\n")
cat("connectors (rank-positive) vs. core-but-not-bridging (rank-negative).\n")
cat("\n=== Community composition table ===\n")
comm_table <- aggregate(modality ~ community + variable, data = mod_df,
FUN = function(x) paste(x, collapse = "; "))
comm_table$label <- vapply(as.character(comm_table$community),
function(k) {
lab <- comm_label_map[[k]]
if (is.null(lab)) paste0("C", k) else lab
}, character(1))
comm_table <- comm_table[order(comm_table$community, comm_table$variable), ]
print(comm_table[, c("label", "variable", "modality")],
row.names = FALSE)
cat("\n=== Cross-stratifier invariance summary ===\n")
cat("Running joint_balance() across each of the 6 demographics ",
"(this takes ~3 minutes)...\n\n")
prepare_for_strat <- function(dat, strat) {
d <- dat[, c(strat, PREF_VARS)]
d <- d[!is.na(d[[strat]]), ]
if (strat == "GEND") {
d <- d[d$GEND != "Prefer not to disclose", ]
d$GEND <- droplevels(d$GEND)
}
d
}
results <- list()
for (strat in DEMOG_VARS) {
d <- prepare_for_strat(dat, strat)
jb <- tryCatch({
joint_balance(d, group = strat,
n_perm = 500, n_perm_edge = 300,
seed = 1, verbose = FALSE)
}, error = function(e) NULL)
if (!is.null(jb)) {
results[[strat]] <- list(
jb         = jb,
n          = nrow(d),
n_pairs    = nrow(jb$pairwise_omnibus),
min_p      = min(jb$pairwise_omnibus$p_value, na.rm = TRUE),
min_p_bonf = min(jb$pairwise_omnibus$p_bonferroni, na.rm = TRUE),
n_pairs_reject = sum(jb$pairwise_omnibus$p_bonferroni < jb$alpha,
na.rm = TRUE),
n_marg_sig = sum(jb$marginal$p_adjusted < jb$alpha, na.rm = TRUE),
n_marg_total = nrow(jb$marginal)
)
cat(sprintf("  %-8s  n=%d  pairs=%2d  min_p_bonf=%.3f  marg_sig=%d/%d\n",
strat, nrow(d), nrow(jb$pairwise_omnibus),
results[[strat]]$min_p_bonf,
results[[strat]]$n_marg_sig, nrow(jb$marginal)))
}
}
# Cross-stratifier summary
summary_df <- do.call(rbind, lapply(names(results), function(s) {
r <- results[[s]]
data.frame(
stratifier = s,
n          = r$n,
n_pairs    = r$n_pairs,
n_pairs_reject = sprintf("%d/%d", r$n_pairs_reject, r$n_pairs),
n_marg_sig = sprintf("%d/%d", r$n_marg_sig, r$n_marg_total),
min_p_raw  = r$min_p,
min_p_bonferroni = r$min_p_bonf,
stringsAsFactors = FALSE
)
}))
summary_df$min_p_holm_across_strat <- p.adjust(
summary_df$min_p_bonferroni, method = "holm")
summary_df <- summary_df[order(summary_df$min_p_bonferroni), ]
cat("\n=== Final invariance summary ===\n")
print(summary_df, row.names = FALSE, digits = 3)
n_strat_reject <- sum(summary_df$min_p_holm_across_strat < 0.05)
cat("\nStratifiers rejecting after full multiple-comparisons correction:",
n_strat_reject, "of", nrow(summary_df), "\n")
library(graphics)
bar_data <- summary_df
bar_data$neglog_holm  <- -log10(pmax(bar_data$min_p_holm_across_strat, 1e-4))
bar_data$neglog_bonf  <- -log10(pmax(bar_data$min_p_bonferroni, 1e-4))
bar_data <- bar_data[order(bar_data$neglog_holm), ]
op <- graphics::par(mar = c(4, 7, 3, 2))
ylim_max <- max(bar_data$neglog_bonf, bar_data$neglog_holm, -log10(0.05)) * 1.1
ypos <- barplot(
rbind(bar_data$neglog_bonf, bar_data$neglog_holm),
beside    = TRUE,
horiz     = TRUE,
names.arg = bar_data$stratifier,
las       = 1,
col       = c("#7F77DD", "#534AB7"),
border    = NA,
xlab      = expression(-log[10](p)),
main      = "Joint preference-architecture invariance across demographics",
xlim      = c(0, ylim_max)
)
abline(v = -log10(0.05), lty = 2, col = "grey30")
graphics::legend("bottomright",
legend = c("within-stratifier (Bonferroni)",
"across-stratifier (Holm)"),
fill   = c("#7F77DD", "#534AB7"),
border = NA, bty = "n", cex = 0.85,
inset  = c(0, 0))
graphics::text(x = -log10(0.05), y = max(ypos) + 0.5,
labels = expression(p == 0.05),
pos = 3, cex = 0.8, col = "grey30")
graphics::par(op)
cat("\n=== AGE: descriptive look at the pre-correction signal ===\n")
if ("AGE" %in% names(results)) {
jb_age <- results[["AGE"]]$jb
po_age <- jb_age$pairwise_omnibus
po_age <- po_age[order(po_age$p_value), ]
cat("Pairwise omnibus tests across age:\n")
print(po_age[, c("group_x", "group_y", "n_x", "n_y",
"observed", "p_value", "p_bonferroni")],
row.names = FALSE, digits = 3)
# Top pair (strongest pre-correction signal)
top <- po_age[1L, ]
cat(sprintf("\nStrongest signal: %s vs %s (raw p=%.3f, bonf p=%.3f)\n",
top$group_x, top$group_y, top$p_value, top$p_bonferroni))
cat("This is the within-stratifier Bonferroni p, NOT corrected across\n")
cat("the choice of stratifier. Treat as descriptive/exploratory only.\n\n")
# Find the edgewise result for this pair (handles either ordering)
pair_key <- paste0(top$group_x, "_vs_", top$group_y)
if (!pair_key %in% names(jb_age$pairwise_edgewise)) {
pair_key <- paste0(top$group_y, "_vs_", top$group_x)
}
if (pair_key %in% names(jb_age$pairwise_edgewise)) {
et <- jb_age$pairwise_edgewise[[pair_key]]
cat("Top 10 edges differing between these age groups (descriptive):\n")
top_e <- head(et$edge_table[order(et$edge_table$p_adjusted), ], 10)
print(top_e[, c("from", "to", "weight_x", "weight_y",
"obs_diff", "p_adjusted")],
row.names = FALSE, digits = 3)
# ---- The plot the section was supposed to produce ----
n_sig <- sum(et$edge_table$p_adjusted < 0.05, na.rm = TRUE)
cat("\nEdges surviving BH p<0.05 within this pair:", n_sig, "\n")
if (n_sig >= 1L) {
alpha_use   <- 0.05
show_ns_use <- FALSE
cat("Plotting at BH p<0.05.\n")
} else {
alpha_use   <- 0.10
show_ns_use <- FALSE
n_relax <- sum(et$edge_table$p_adjusted < alpha_use, na.rm = TRUE)
cat(sprintf("No edges at BH p<0.05; relaxing to p<%.2f for ",
alpha_use))
cat("descriptive plot only.\n")
cat("Edges at relaxed threshold:", n_relax, "\n")
}
# Filter rare modalities (n<20 in the full sample) to declutter
mod_counts <- unlist(lapply(PREF_VARS, function(v) {
tab <- table(dat_pref[[v]])
setNames(as.integer(tab), paste0(v, "=", names(tab)))
}))
rare_mods <- names(mod_counts)[mod_counts < 20L]
if (length(rare_mods) > 0L) {
cat("Excluding rare modalities (n<20):",
paste(rare_mods, collapse = "; "), "\n")
et_filt <- et
et_filt$edge_table <- et$edge_table[
!(et$edge_table$from %in% rare_mods |
et$edge_table$to   %in% rare_mods), , drop = FALSE]
} else {
et_filt <- et
}
n_after_filter <- sum(et_filt$edge_table$p_adjusted < alpha_use,
na.rm = TRUE)
if (n_after_filter == 0L) {
cat("After rare-modality filter, no edges survive at p<",
alpha_use, ". Skipping plot.\n", sep = "")
} else {
gx <- top$group_x; gy <- top$group_y
# Match the side that exists in modality_graphs
if (!gx %in% names(jb_age$modality_graphs)) {
gx <- top$group_y; gy <- top$group_x
}
plot_modality_difference(
et_filt,
reference    = list(jb_age$modality_graphs[[gx]],
jb_age$modality_graphs[[gy]]),
group_labels = c(paste("stronger in", gx),
paste("stronger in", gy)),
alpha_fdr    = alpha_use,
show_nonsig  = show_ns_use,
title        = sprintf(
"AGE pre-correction signal: %s vs %s\n(descriptive only — absorbed by across-stratifier Holm)",
gx, gy)
)
}
}
}
cat("\n\n=== Final summary ===\n\n")
cat("Variable-level preference network:\n")
cat("  ", igraph::ecount(cg_pruned$graph), "edges retained at BH p<0.05, V>=0.10\n")
cat("  Strongest edges: PURFRE-PPL (0.27), RFQ-MIPB1T (0.21),\n")
cat("                   RFQ-PPL (0.19), MIPB1T-MIPBREP (0.18)\n")
cat("  CCP (communication channel) is essentially disconnected\n\n")
cat("Modality-level architecture:\n")
cat("  ", igraph::vcount(mg_keep$graph), "modalities organize into",
n_big, "coherent communities:\n")
for (k in names(comm_label_map)) {
if (k %in% as.character(big_comms)) {
cat("    ", comm_label_map[[k]], "\n")
}
}
cat("\nDemographic invariance:\n")
cat("  Stratifiers tested:", nrow(summary_df), "\n")
cat("  Reject at within-stratifier Bonferroni:",
sum(summary_df$min_p_bonferroni < 0.05), "\n")
cat("  Reject at across-stratifier Holm:",
sum(summary_df$min_p_holm_across_strat < 0.05), "\n\n")
cat("Headline: a coherent three-orientation preference architecture exists,\n")
cat("and is invariant across age, employment, education, income, residence,\n")
cat("and gender after multiple-comparisons correction. AGE shows a pre-\n")
cat("correction signal (Bonferroni p=0.020 within stratifier, absorbed by\n")
cat("Holm across the choice of stratifier) that is suggestive but not\n")
cat("confirmatory.\n")
cat("\n=== Analysis complete ===\n")
# Helper for fallback labels
`%||%` <- function(x, y) if (is.null(x)) y else x
