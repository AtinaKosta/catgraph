# ---- 6. MCA modality map enriched with catgraph scores -----------------------
# FactoMineR labels do not always exactly equal catgraph labels. This resolver
# tries exact, variable_level, variable=level, and unique-level matching.
resolve_mca_to_catgraph <- function(mca_labels, active_data) {
candidates <- lapply(names(active_data), function(v) {
levs <- levels(active_data[[v]])
data.frame(
variable = v,
modality = levs,
node = paste0(v, "=", levs),
cand_exact = levs,
cand_us = paste0(v, "_", levs),
cand_eq = paste0(v, "=", levs),
stringsAsFactors = FALSE
)
}) |> bind_rows()
out <- data.frame(mca_label = mca_labels, node = NA_character_, stringsAsFactors = FALSE)
for (i in seq_along(mca_labels)) {
lab <- mca_labels[i]
hit <- which(candidates$cand_eq == lab)
if (length(hit) == 0) hit <- which(candidates$cand_us == lab)
if (length(hit) == 0) hit <- which(candidates$cand_exact == lab)
# Fallback: label contains both variable and modality
if (length(hit) == 0) {
hit <- which(vapply(seq_len(nrow(candidates)), function(k) {
grepl(candidates$variable[k], lab, fixed = TRUE) &&
grepl(candidates$modality[k], lab, fixed = TRUE)
}, logical(1)))
}
# Fallback: modality text is unique across all active variables
if (length(hit) == 0) {
modality_hit <- which(candidates$modality == lab)
if (length(modality_hit) == 1) hit <- modality_hit
}
if (length(hit) >= 1) out$node[i] <- candidates$node[hit[1]]
}
out
}
mca_mod <- data.frame(
mca_label = rownames(res_mca$var$coord),
Dim1 = res_mca$var$coord[, 1],
Dim2 = res_mca$var$coord[, 2],
contrib12 = res_mca$var$contrib[, 1] + res_mca$var$contrib[, 2],
cos2_12 = res_mca$var$cos2[, 1] + res_mca$var$cos2[, 2],
stringsAsFactors = FALSE
)
map_mca <- resolve_mca_to_catgraph(mca_mod$mca_label, tea_active)
mca_catgraph_mod <- mca_mod |>
left_join(map_mca, by = "mca_label") |>
left_join(grav, by = "node")
cat("\nMCA-to-catgraph modality matching rate: ",
sum(!is.na(mca_catgraph_mod$node)), " / ", nrow(mca_catgraph_mod), "\n", sep = "")
print(
ggplot(mca_catgraph_mod, aes(x = Dim1, y = Dim2)) +
geom_hline(yintercept = 0, linetype = 2, linewidth = 0.3) +
geom_vline(xintercept = 0, linetype = 2, linewidth = 0.3) +
geom_point(aes(size = strength, shape = role), alpha = 0.75, na.rm = TRUE) +
ggrepel::geom_text_repel(aes(label = mca_label), size = 2.6, max.overlaps = 80) +
scale_size_continuous(range = c(1.5, 7), na.value = 1.5) +
labs(
title = "MCA modality space enriched with catgraph modality strength",
subtitle = "Coordinates come from MCA; point size/role come from catgraph gravity indices",
x = "MCA Dimension 1",
y = "MCA Dimension 2",
size = "catgraph strength",
shape = "gravity role"
) +
theme_minimal()
)
print(
ggplot(mca_catgraph_mod, aes(x = Dim1, y = Dim2)) +
geom_hline(yintercept = 0, linetype = 2, linewidth = 0.3) +
geom_vline(xintercept = 0, linetype = 2, linewidth = 0.3) +
geom_point(aes(size = abs(delta_mgi), shape = role), alpha = 0.75, na.rm = TRUE) +
ggrepel::geom_text_repel(aes(label = mca_label), size = 2.6, max.overlaps = 80) +
scale_size_continuous(range = c(1.5, 7), na.value = 1.5) +
labs(
title = "MCA modality map enriched with catgraph dMGI magnitude",
subtitle = "MCA shows projection geometry; catgraph adds prevalence-aware attractor/satellite structure",
x = "MCA Dimension 1",
y = "MCA Dimension 2",
size = "|dMGI|",
shape = "gravity role"
) +
theme_minimal()
)
